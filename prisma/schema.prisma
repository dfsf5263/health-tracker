model Migraine {
  id                    String                 @id @default(uuid()) @db.Uuid
  userId                String                 @map("user_id") @db.Uuid
  startDateTime         DateTime               @map("start_date_time")
  endDateTime           DateTime?              @map("end_date_time")
  painLevel             Int                    @map("pain_level")
  geographicLocation    String?                @map("geographic_location")
  periodStatus          PeriodStatus?          @map("period_status")
  notes                 String?
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  migraineMigraineAttackTypes       MigraineMigraineAttackType[]
  migraineMigraineSymptomTypes      MigraineMigraineSymptomType[]
  migraineMigraineTriggerTypes      MigraineMigraineTriggerType[]
  migraineMigrainePrecognitionTypes MigraineMigrainePrecognitionType[]
  migraineMigraineMedicationTypes   MigraineMigraineMedicationType[]
  migraineMigraineReliefTypes       MigraineMigraineReliefType[]
  migraineMigraineActivityTypes     MigraineMigraineActivityType[]
  migraineMigraineLocationTypes     MigraineMigraineLocationType[]

  @@index([userId])
  @@map("migraine")
}

