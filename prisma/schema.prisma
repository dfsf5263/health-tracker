generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(uuid()) @db.Uuid
  clerkUserId           String                 @unique @map("clerk_user_id")
  email                 String                 @unique
  firstName             String?                @map("first_name")
  lastName              String?                @map("last_name")
  averageCycleLength    Float?                 @map("average_cycle_length")
  averagePeriodLength   Float?                 @map("average_period_length")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")

  cycles                Cycle[]
  periodDays            PeriodDay[]
  birthControlTypes     BirthControlType[]
  birthControlDays      BirthControlDay[]
  irregularPhysicalTypes IrregularPhysicalType[]
  irregularPhysicalDays  IrregularPhysicalDay[]
  normalPhysicalTypes   NormalPhysicalType[]
  normalPhysicalDays    NormalPhysicalDay[]
  migraineAttackTypes   MigraineAttackType[]
  migraineSymptomTypes   MigraineSymptomType[]
  migraineTriggerTypes   MigraineTriggerType[]
  migrainePrecognitionTypes   MigrainePrecognitionType[]
  migraineMedicationTypes   MigraineMedicationType[]
  migraineReliefTypes   MigraineReliefType[]
  migraineActivityTypes   MigraineActivityType[]
  migraines             Migraine[]

  @@map("user")
}

model Cycle {
  id                    String                 @id @default(uuid()) @db.Uuid
  userId                String                 @map("user_id") @db.Uuid
  startDate             DateTime               @map("start_date") @db.Date
  endDate               DateTime               @map("end_date") @db.Date
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("cycle")
}

enum Flow {
  Spotting
  Medium
  Heavy
  SuperHeavy
}

enum Color {
  Red
  Brown
}

enum PeriodStatus {
  Yes
  No
  Upcoming
}

model PeriodDay {
  id                    String                 @id @default(uuid()) @db.Uuid
  userId                String                 @map("user_id") @db.Uuid
  date                  DateTime               @db.Date
  flow                  Flow
  color                 Color
  notes                 String?
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@map("period_day")
}

model BirthControlType {
  id                    String                 @id @default(uuid()) @db.Uuid
  userId                String                 @map("user_id") @db.Uuid
  name                  String
  vaginalRingInsertion  Boolean                @default(false) @map("vaginal_ring_insertion")
  vaginalRingRemoval    Boolean                @default(false) @map("vaginal_ring_removal")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthControlDays      BirthControlDay[]

  @@unique([userId, name])
  @@index([userId])
  @@map("birth_control_type")
}

model BirthControlDay {
  id                    String                 @id @default(uuid()) @db.Uuid
  userId                String                 @map("user_id") @db.Uuid
  date                  DateTime               @db.Date
  typeId                String                 @map("type_id") @db.Uuid
  notes                 String?
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                  BirthControlType       @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@unique([userId, date, typeId])
  @@index([userId])
  @@index([typeId])
  @@map("birth_control_day")
}

