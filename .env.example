# Environment variables template
# Copy this file to .env and fill in the actual values

# Database configuration
# Format: postgresql://username:password@host:port/database?schema=public
DATABASE_URL="postgresql://your_username:your_password@your_host:5432/your_database?schema=public"

# Better Auth Configuration
# Generate a random secret for session signing (32+ characters recommended)
BETTER_AUTH_SECRET="your_better_auth_secret_key_32_characters_or_more"

# Application URL for authentication callbacks and email links
APP_URL="http://localhost:3000"

# Email Service Configuration (Resend)
# Get your API key from https://resend.com
RESEND_API_KEY="re_your_api_key"

# From email address - use onboarding@resend.dev for development, your verified domain for production
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Reply-to email address (optional) - where recipients can reply for support
RESEND_REPLY_TO_EMAIL="support@yourdomain.com"

# E2E testing — local Postgres instance via Docker (port 5433 avoids colliding with dev DB on 5432)
DATABASE_URL_E2E="postgresql://postgres:postgres@localhost:5433/health_tracker_e2e"

# E2E test user credentials — must match a seeded account with emailVerified=true
E2E_EMAIL="e2e@test.local"
E2E_PASSWORD="E2eTestPassword1!"
